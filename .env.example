# Copy this file to .env.local and fill in your real values.
# .env.local is gitignored and will NEVER be uploaded to GitHub.

# ─── Supabase (FREE) ──────────────────────────────────────────────────────────
# Create free project at https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxx

# Service role key — used ONLY server-side for admin user management.
# Find it in: Supabase Dashboard → Project Settings → API → service_role (secret)
# Add this to Vercel environment variables too (NOT prefixed with NEXT_PUBLIC_).
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxx

# ─── Resend Email (FREE — 3,000 emails/month) ─────────────────────────────────
# Get free API key at https://resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Razorpay (TEST MODE — free, no real money) ───────────────────────────────
# Create free account at https://razorpay.com → Settings → API Keys → Test Mode
# Test card: 4111 1111 1111 1111 | Expiry: any future | CVV: any | OTP: 1234
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Public key for client-side checkout (same as KEY_ID, safe to expose)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx

# ─── App URL (used for absolute URLs in email links) ─────────────────────────
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
